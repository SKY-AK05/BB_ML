{
  "version": 2,
  "name": "annotcheck",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "public",
  "framework": null
}
