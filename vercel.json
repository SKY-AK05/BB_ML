{
  "version": 2,
  "name": "annotcheck",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.py": {
      "runtime": "python3.9",
      "handler": "annotcheck_desktop.app"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "python build.py && mkdir -p public/api && cp annotcheck_desktop.py public/api/index.py",
  "outputDirectory": "public",
  "framework": null
}
