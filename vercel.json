{
  "version": 2,
  "name": "annotcheck",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
    "buildCommand": "python build.py",
  "outputDirectory": "public",
  "framework": null
}
